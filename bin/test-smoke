#!/usr/bin/env bash
# Smoke-test live deploys end-to-end: hit the public R2 indexes, the
# Pages Function endpoints, and the deep-link routes. Exit non-zero on
# any failure. Cheap (~5s) — meant to run after every deploy.
set -euo pipefail
BASE="${BASE:-https://vtt-ui.pages.dev}"
PUB="${PUB:-https://pub-868d2bf7e2f6434c860d65dfe1cadad4.r2.dev}"
fail=0
ok()   { printf "  \033[32m✓\033[0m %s\n" "$*"; }
bad()  { printf "  \033[31m✗\033[0m %s\n" "$*"; fail=$((fail+1)); }
hit() {
  local label="$1" url="$2" need="${3:-}"
  local code
  code=$(curl -s --compressed -o /tmp/_smoke_body -w "%{http_code}" "$url" || echo "000")
  if [ "$code" = "200" ]; then
    if [ -z "$need" ] || grep -qF -- "$need" /tmp/_smoke_body; then
      ok "$label"
    else
      bad "$label — 200 but missing pattern: $need"
    fi
  else
    bad "$label — HTTP $code"
  fi
}

echo "== R2 public indexes =="
hit "creators/index.json"    "$PUB/creators/index.json"    '"creators"'
hit "vods/index.json"        "$PUB/vods/index.json"        '"vods"'
hit "events/index.json"      "$PUB/events/index.json"      '"events"'

echo "== Pages Functions =="
hit "/api/creators"          "$BASE/api/creators"          '"creators"'
hit "/api/search?q=clutch"   "$BASE/api/search?q=clutch"
hit "/api/events"            "$BASE/api/events"            '"hits"'
hit "/api/auth/me"           "$BASE/api/auth/me"           '"authenticated"'

echo "== Static page =="
hit "/ index.html"           "$BASE/"                      '<title>vtt'
hit "?mode=event"            "$BASE/?mode=event"           '<title>vtt'

echo "== Auth gates =="
# Anonymous vote MUST be rejected with 401 — the Pages Function reads the
# vtt_session cookie and forwards X-VTT-User-Sub to serve.py. Without the
# cookie, no proxy hop happens and no manifest row gets written.
auth_code=$(curl -s --compressed -X POST "$BASE/api/event_label/append" \
  -H "content-type: application/json" \
  -d '{"creator":"_smoke","basename":"_smoke","event":"_smoke","t_sec":0,"label":1}' \
  -o /dev/null -w "%{http_code}")
if [ "$auth_code" = "401" ]; then
  ok "/api/event_label/append rejects anon (401)"
else
  bad "/api/event_label/append should 401 anon, got HTTP $auth_code"
fi

# /api/scan/queue is the same shape — POST + auth-gated.
scan_code=$(curl -s --compressed -X POST "$BASE/api/scan/queue" \
  -H "content-type: application/json" \
  -d '{"creator":"_smoke","basename":"_smoke"}' \
  -o /dev/null -w "%{http_code}")
if [ "$scan_code" = "401" ]; then
  ok "/api/scan/queue rejects anon (401)"
else
  bad "/api/scan/queue should 401 anon, got HTTP $scan_code"
fi

# /api/scan/status is public passthrough; missing job_id should 400.
status_code=$(curl -s --compressed "$BASE/api/scan/status" \
  -o /dev/null -w "%{http_code}")
if [ "$status_code" = "400" ]; then
  ok "/api/scan/status rejects missing job_id (400)"
else
  bad "/api/scan/status should 400 without job_id, got HTTP $status_code"
fi

# /api/scan/download_and_queue is auth-gated like /api/scan/queue.
dl_scan_code=$(curl -s --compressed -X POST "$BASE/api/scan/download_and_queue" \
  -H "content-type: application/json" \
  -d '{"creator":"jagerzgoober","basename":"2026-04-08_drops-adept-roulette-discord-user-socials-dbdcreat"}' \
  -o /dev/null -w "%{http_code}")
if [ "$dl_scan_code" = "401" ]; then
  ok "/api/scan/download_and_queue rejects anon (401)"
else
  bad "/api/scan/download_and_queue should 401 anon, got HTTP $dl_scan_code"
fi

echo "== VOD availability (requires serve.py restart) =="
# NOTE: these hit serve.py directly via the tunnel URL. Run only after
# restarting serve.py with the new vod_scan_chain / vod_availability changes.
# The adept-roulette VOD has a meta sidecar with stream_id but no local mp4.
LOCAL="${LOCAL:-http://localhost:8765}"
avail_code=$(curl -s --compressed \
  "${LOCAL}/api/vod/availability?creator=jagerzgoober&basename=2026-04-08_drops-adept-roulette-discord-user-socials-dbdcreat" \
  -o /tmp/_smoke_avail -w "%{http_code}" 2>/dev/null || echo "000")
if [ "$avail_code" = "200" ]; then
  # Python's json.dumps default emits `"key": false` (with space after :);
  # the live response has spaces, so match with grep -E and \s* tolerance
  # rather than literal-string grep -F which silently misses.
  if grep -qE '"available":\s*false' /tmp/_smoke_avail && grep -qE '"has_stream_id":\s*true' /tmp/_smoke_avail; then
    ok "/api/vod/availability jagerzgoober/adept-roulette → available:false, has_stream_id:true"
  else
    bad "/api/vod/availability jagerzgoober/adept-roulette — 200 but wrong body: $(cat /tmp/_smoke_avail)"
  fi
else
  bad "/api/vod/availability jagerzgoober/adept-roulette — HTTP $avail_code (serve.py may need restart)"
fi

echo "== Demo-chip queries =="
# Every example chip on the landing page must return ≥1 hit against the
# live corpus. A demo chip that lands on "no matches" undersells the
# product. The site-side EXAMPLE_QUERIES constant is the source of
# truth; this list mirrors it.
for q in "no way bro" "let's go" "oh my god" "what the hell" "on hook" "gen pop"; do
  q_enc=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$q")
  total=$(curl -s --compressed "$BASE/api/search?q=$q_enc" 2>/dev/null \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('n_total',0))" 2>/dev/null)
  if [ -n "$total" ] && [ "$total" != "0" ]; then
    ok "demo chip \"$q\" → $total hits"
  else
    bad "demo chip \"$q\" → 0 hits (broken demo on landing)"
  fi
done

if [ $fail -gt 0 ]; then
  printf "\n\033[31mFAILED %d check(s)\033[0m\n" "$fail"
  exit 1
fi
printf "\n\033[32mall good\033[0m\n"
