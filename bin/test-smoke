#!/usr/bin/env bash
# Smoke-test live deploys end-to-end: hit the public R2 indexes, the
# Pages Function endpoints, and the deep-link routes. Exit non-zero on
# any failure. Cheap (~5s) — meant to run after every deploy.
set -euo pipefail
BASE="${BASE:-https://vtt-ui.pages.dev}"
PUB="${PUB:-https://pub-868d2bf7e2f6434c860d65dfe1cadad4.r2.dev}"
fail=0
ok()   { printf "  \033[32m✓\033[0m %s\n" "$*"; }
bad()  { printf "  \033[31m✗\033[0m %s\n" "$*"; fail=$((fail+1)); }
hit() {
  local label="$1" url="$2" need="${3:-}"
  local code
  code=$(curl -s --compressed -o /tmp/_smoke_body -w "%{http_code}" "$url" || echo "000")
  if [ "$code" = "200" ]; then
    if [ -z "$need" ] || grep -qF -- "$need" /tmp/_smoke_body; then
      ok "$label"
    else
      bad "$label — 200 but missing pattern: $need"
    fi
  else
    bad "$label — HTTP $code"
  fi
}

echo "== R2 public indexes =="
hit "creators/index.json"    "$PUB/creators/index.json"    '"creators"'
hit "vods/index.json"        "$PUB/vods/index.json"        '"vods"'
hit "events/index.json"      "$PUB/events/index.json"      '"events"'

echo "== Pages Functions =="
hit "/api/creators"          "$BASE/api/creators"          '"creators"'
hit "/api/search?q=clutch"   "$BASE/api/search?q=clutch"
hit "/api/events"            "$BASE/api/events"            '"hits"'
hit "/api/auth/me"           "$BASE/api/auth/me"           '"authenticated"'

echo "== Static page =="
hit "/ index.html"           "$BASE/"                      '<title>vtt'
hit "?mode=event"            "$BASE/?mode=event"           '<title>vtt'

echo "== Auth gates =="
# Anonymous vote MUST be rejected with 401 — the Pages Function reads the
# vtt_session cookie and forwards X-VTT-User-Sub to serve.py. Without the
# cookie, no proxy hop happens and no manifest row gets written.
auth_code=$(curl -s --compressed -X POST "$BASE/api/event_label/append" \
  -H "content-type: application/json" \
  -d '{"creator":"_smoke","basename":"_smoke","event":"_smoke","t_sec":0,"label":1}' \
  -o /dev/null -w "%{http_code}")
if [ "$auth_code" = "401" ]; then
  ok "/api/event_label/append rejects anon (401)"
else
  bad "/api/event_label/append should 401 anon, got HTTP $auth_code"
fi

if [ $fail -gt 0 ]; then
  printf "\n\033[31mFAILED %d check(s)\033[0m\n" "$fail"
  exit 1
fi
printf "\n\033[32mall good\033[0m\n"
